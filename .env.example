PORT=8791
# Optional richer data: APIFOOTBALL_KEY=   (free tier at api-football.com)

# --- x402 payment (all optional; empty = demo mode, the zero-config default) ---
PAY_TO=0x0000000000000000000000000000000000000000   # your receiving address
PRICE_UNITS=5000                                     # 0.005 USDC (6 decimals)
CHAIN_ID=1439                                        # Injective EVM testnet

# Set USDC_ADDRESS to turn on real EIP-3009 signature VERIFICATION:
# USDC_ADDRESS=0x...                                 # testnet USDC contract
# USDC_NAME=USD Coin                                 # must match token EIP-712 domain
# USDC_VERSION=2

# Add these to also SETTLE on-chain (relayer submits transferWithAuthorization):
# RPC_URL=https://k8s.testnet.json-rpc.injective.network/
# RELAYER_PRIVATE_KEY=0x...                          # pays gas; never commit a real key

# Shared secret so HTTP-issued payment tokens validate in the MCP server:
# TOKEN_SECRET=change-me-to-a-long-random-string

# --- CCTP funding (scripts/fund-agent.ts; npm run fund) ---
# SRC_RPC=...            # source-chain RPC (where you hold USDC)
# SRC_PRIVATE_KEY=0x...  # funds the burn
# SRC_USDC=0x...         # USDC on the source chain
# SRC_TOKEN_MESSENGER=0x...  # CCTP TokenMessenger on the source chain
# AGENT_ADDRESS=0x...    # agent wallet to receive USDC on Injective (domain 29)
# AMOUNT=1000000         # 1 USDC (6dp)
